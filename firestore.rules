rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return signedIn() && currentProfile().role == "teacher";
    }

    function isAdmin() {
      return signedIn() && (
        currentProfile().role == "admin"
        || (request.auth.token.email != null
          && request.auth.token.email.lower() == "ghost8965@gmail.com")
      );
    }

    function teacherSchool() {
      return currentProfile().school;
    }

    function sameSchool(school) {
      return isTeacher()
        && teacherSchool() is string
        && teacherSchool() != ""
        && school == teacherSchool();
    }

    function targetStudentInTeacherSchool(studentId, school) {
      return sameSchool(school)
        && get(/databases/$(database)/documents/profiles/$(studentId)).data.school == teacherSchool()
        && get(/databases/$(database)/documents/profiles/$(studentId)).data.role == "student";
    }

    match /profiles/{uid} {
      allow read: if isOwner(uid) || isAdmin() || sameSchool(resource.data.school);
      allow create: if isOwner(uid)
        && request.resource.data.role == "student";
      allow update: if (
          isOwner(uid)
          && request.resource.data.role == resource.data.role
        ) || isAdmin() || (
          isTeacher()
          && resource.data.role == "student"
          && resource.data.school == teacherSchool()
          && request.resource.data.school == teacherSchool()
          && request.resource.data.role == resource.data.role
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["school", "studentNumber", "name", "updatedAt"])
        );
      allow delete: if false;
    }

    match /engineeringNotes/{noteId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || sameSchool(resource.data.school);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /aiQuestions/{questionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || sameSchool(resource.data.school);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if false;
    }

    match /progress/{progressId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || sameSchool(resource.data.school);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /pdfSubmissions/{userId} {
      allow read: if isOwner(userId) || isAdmin() || sameSchool(resource.data.school);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /teacherQuestions/{questionId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "unread"
        && request.resource.data.teacherAnswer == null
        && request.resource.data.answeredBy == null
        && request.resource.data.answeredAt == null;
      allow read: if isOwner(resource.data.userId) || isAdmin() || sameSchool(resource.data.school);
      allow update: if isAdmin() || (
          sameSchool(resource.data.school)
          && resource.data.status != "answered"
          && request.resource.data.status in ["read", "answered"]
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "teacherAnswer", "answeredBy", "answeredAt", "updatedAt"])
        );
      allow delete: if false;
    }

    match /studentFeedback/{feedbackId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || sameSchool(resource.data.school);
      allow create: if isAdmin() || (
          isTeacher()
          && request.resource.data.teacherId == request.auth.uid
          && targetStudentInTeacherSchool(request.resource.data.studentId, request.resource.data.school)
        );
      allow update: if (
          isOwner(resource.data.studentId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["isRead", "updatedAt"])
          && request.resource.data.isRead == true
        ) || isAdmin() || (
          isTeacher()
          && resource.data.teacherId == request.auth.uid
          && sameSchool(resource.data.school)
          && request.resource.data.teacherId == resource.data.teacherId
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.school == resource.data.school
        );
      allow delete: if isAdmin() || (
        isTeacher()
        && resource.data.teacherId == request.auth.uid
        && sameSchool(resource.data.school)
      );
    }

    match /systemSettings/teacherQuestion {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
  }
}
